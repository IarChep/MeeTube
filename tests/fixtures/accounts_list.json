          "multiPageMenuRenderer": {
            "sections": [
              {
                "accountSectionListRenderer": {
                  "contents": [
                    {
                      "accountItemSectionRenderer": {
                        "contents": [
                          {
                            "accountItem": {
                              "accountName": { "simpleText": "Ivan Petrov" },
